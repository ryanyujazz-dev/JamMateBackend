  "agent_today_guidance_runtime_smoke": {
    "version": "v2_10_7",
    "script": "curl_agent_today_guidance_runtime_smoke.sh",
    "default_base_url": "http://127.0.0.1:8000",
    "default_sqlite_db_path": "/tmp/jammate_agent_harmonyos_today_guidance_runtime_smoke.sqlite",
    "purpose": "Run a strict FastAPI runtime smoke for the two HarmonyOS Agent product routes without calling Engine or playback routes.",
    "command": "bash curl_agent_today_guidance_runtime_smoke.sh http://127.0.0.1:8000 /tmp/jammate_agent_harmonyos_today_guidance_runtime_smoke.sqlite",
    "sequence": [
      {
        "step": 1,
        "method": "GET",
        "path": "/health",
        "expect": {
          "http_status": 200
        }
      },
      {
        "step": 2,
        "method": "POST",
        "path": "/agent/harmonyos/routine-completion-record/execute",
        "request_file": "smoke_agent_harmonyos_routine_completion_record_execute.json",
        "expect": {
          "http_status": 200,
          "ok": true,
          "code": "routine_completion_record_persisted",
          "data.completionRecordPersisted": true,
          "data.nextTodayGuidanceCanReadHistory": true,
          "debug.backendDatabaseWritten": true,
          "safety.backendSQLiteWriteMayOccur": true,
          "safety.writesHarmonyOSLocalState": false,
          "safety.startsRoutine": false,
          "safety.callsEngineAdapter": false,
          "safety.createsMidiAsset": false,
          "safety.startsPlayback": false
        }
      },
      {
        "step": 3,
        "method": "POST",
        "path": "/agent/harmonyos/today-practice-guidance/preview",
        "request_file": "smoke_agent_harmonyos_today_practice_guidance_preview.json",
        "expect": {
          "http_status": 200,
          "ok": true,
          "code": "today_guidance_ready",
          "data.guidancePreviewReady": true,
          "data.contextSource": "sqlite_backend",
          "data.requiresUserConfirmationBeforeRoutineStart": true,
          "debug.sqliteReadbackAttempted": true,
          "debug.backendDatabaseRead": true,
          "debug.sqliteRowsRead": "greater_than_or_equal:1",
          "safety.backendSQLiteWriteMayOccur": false,
          "safety.writesHarmonyOSLocalState": false,
          "safety.startsRoutine": false,
          "safety.callsEngineAdapter": false,
          "safety.createsMidiAsset": false,
          "safety.startsPlayback": false
        }
      }
    ],
    "excluded_routes": [
      "/accompaniment/generate",
      "/agent/playback/prepare"
    ],
    "side_effects": {
      "backend_sqlite_write": "only in step 2 and only because the fixture explicitly confirms record write",
      "backend_sqlite_read": "step 3 reads persisted context",
      "harmonyos_local_state_write": false,
      "routine_start": false,
      "engine_adapter_call": false,
      "midi_generation": false,
      "playback_start": false
    }
  }
